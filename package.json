{
  "name": "openwren",
  "version": "2026.3.4",
  "description": "Self-hosted personal AI assistant bot with multi-channel support (Telegram, Discord, WebSocket)",
  "main": "dist/index.js",
  "bin": {
    "openwren": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && rm -rf dist/templates && cp -r src/templates dist/templates",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "cli": "ts-node src/cli.ts",
    "scratch": "ts-node src/scratch.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "bot",
    "telegram",
    "discord",
    "claude",
    "ollama",
    "self-hosted",
    "personal-assistant"
  ],
  "author": "Nermin Bajagilovic <nermion@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openwrenai/openwren.git"
  },
  "homepage": "https://github.com/openwrenai/openwren",
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.77.0",
    "@fastify/websocket": "^11.2.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "grammy": "^1.40.0",
    "json5": "^2.2.3"
  }
}
