// ─────────────────────────────────────────────────
// Open Wren — User Configuration
// ─────────────────────────────────────────────────
// Uncomment and edit any line to override defaults.
// Dot-notation keys map into the nested config:
//   "defaultModel" → config.defaultModel
//
// Secrets can reference env vars from ~/.openwren/.env:
//   "users.owner.channelIds.telegram": "${env:OWNER_TELEGRAM_ID}"
//
// Supports JSON5: comments, trailing commas, unquoted keys.
// ─────────────────────────────────────────────────
{
  // --- Model ---
  // "defaultModel": "anthropic/claude-sonnet-4-6",
  // "defaultFallback": "anthropic/claude-haiku-3-5",

  // --- Provider credentials ---
  // "providers.anthropic.apiKey": "${env:ANTHROPIC_API_KEY}",
  // "providers.ollama.baseUrl": "http://localhost:11434",

  // --- Agents ---
  // "agents.atlas.name": "Atlas",
  // "agents.einstein.name": "Einstein",
  // "agents.einstein.model": "anthropic/claude-sonnet-4-6",
  // "agents.einstein.fallback": "anthropic/claude-haiku-3-5",
  // "agents.wizard.name": "Wizard",
  // "agents.personal_trainer.name": "Coach",

  // --- Users ---
  // "users.owner.displayName": "Your Name",
  // "users.owner.channelIds.telegram": "${env:OWNER_TELEGRAM_ID}",
  // "users.owner.channelIds.discord": "${env:OWNER_DISCORD_ID}",

  // --- Channels ---
  // "channels.unauthorizedBehavior": "reject",
  // "channels.rateLimit.maxMessages": 20,
  // "channels.rateLimit.windowSeconds": 60,

  // --- Bindings (connect agents to channels) ---
  // "bindings.telegram.atlas": "${env:TELEGRAM_BOT_TOKEN}",
  // "bindings.telegram.einstein": "${env:EINSTEIN_TELEGRAM_TOKEN}",
  // "bindings.telegram.wizard": "${env:WIZARD_TELEGRAM_TOKEN}",
  // "bindings.telegram.personal_trainer": "${env:COACH_TELEGRAM_TOKEN}",
  // "bindings.discord.atlas": "${env:ATLAS_DISCORD_TOKEN}",
  // "bindings.discord.einstein": "${env:EINSTEIN_DISCORD_TOKEN}",

  // --- Gateway (WebSocket) ---
  // "gateway.wsToken": "${env:WS_TOKEN}",

  // --- Session ---
  // "timezone": "Europe/Stockholm",
  // "session.idleResetMinutes": 0,
  // "session.dailyResetTime": "",

  // --- Skills ---
  // Only allow specific bundled skills (omit to allow all):
  // "skills.allowBundled": ["memory-management", "file-operations"],
  // Disable a specific skill (works for bundled, global, or per-agent):
  // "skills.entries.web-fetch.enabled": false,
  // Load skills from additional directories:
  // "skills.load.extraDirs": ["~/my-shared-skills"],

  // --- Agent Loop ---
  // "agent.maxIterations": 10,
  // "agent.compaction.enabled": true,
  // "agent.compaction.contextWindowTokens": 25000,
  // "agent.compaction.thresholdPercent": 80,
}
